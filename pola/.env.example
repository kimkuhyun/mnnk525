# POLARIS 환경 변수 예시 — 복사: cp .env.example .env

# ─ Qdrant ──────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_COLLECTION_ACTIVE=polaris-1024-cos-blue
QDRANT_COLLECTION_STANDBY=polaris-1024-cos-green

# ─ Neo4j ───────────────────────────────────────────
NEO4J_BOLT_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=polaris_dev_only

# ─ MariaDB ─────────────────────────────────────────
MARIADB_HOST=localhost
MARIADB_PORT=3307
MARIADB_DATABASE=polaris
MARIADB_USER=polaris
MARIADB_PASSWORD=polaris_dev_only
MARIADB_ROOT_PASSWORD=polaris_root_dev_only

# ─ Ollama (임베딩 + LLM) ───────────────────────────
# 외부 GPU 서버 (SSH·내부망) 사용 시 OLLAMA_BASE 만 그 호스트로 변경
# LLM 모델은 환경에 따라 9b/27b/70b 등 자유 선택 (모든 호출이 이 환경변수 사용)
OLLAMA_BASE=http://localhost:11434
# 재현성 권고: `:latest` 대신 digest 명시 (ollama show bge-m3 출력 참고).
#   예) OLLAMA_EMBED_MODEL=bge-m3@sha256:567f1d...
# 동일 텍스트가 다른 vector 로 변하는 사고를 방지. manifest.json 에 digest 동시 기록.
OLLAMA_EMBED_MODEL=bge-m3:latest
OLLAMA_LLM_MODEL=qwen3.5:9b      # qwen3.6:27b / llama3.3:70b 등 사용 가능

# ─ Rerank (Cross-encoder) ──────────────────────────
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ─ 데이터 디렉토리 (raw 수집 + 청크/임베딩 산출물) ───
# 비우면 패키지 루트의 pola/data/ 사용 (기본). 외부 경로 쓰려면 절대경로.
# 자동 생성 하위 구조:
#   {DATA_ROOT}/rawData/{corp_code}/{dart,documents,krx}/   — 5사별 raw
#   {DATA_ROOT}/rawData/_common/{news,ftc,bok,kosis}/       — 매크로 raw
#   {DATA_ROOT}/2_Chuck/{01_filtered,02_meta,02_clean,03_chunks,04_embed}/
#   {DATA_ROOT}/4_dbGoldTest/                               — 평가 산출물
POLARIS_DATA_ROOT=

# ─ API 키 (없으면 해당 소스 skip) ──────────────────
DART_API_KEY=             # https://opendart.fss.or.kr/ — DART 정형 공시
FTC_OPENAPI_KEY=          # https://data.go.kr/ — 공정위 대규모기업집단
BOK_ECOS_KEY=             # https://ecos.bok.or.kr/api — 한국은행 경제통계
KOSIS_KEY=
# corps.json 위치 (DART corp_code 마스터, 118k 회사).
# 기본: 패키지 내장 (src/polaris/data/corps.json). 다른 위치 쓰면 override.
POLARIS_CORP_DB=

# ─ 회사 목록 (CSV) ─────────────────────────────
# 신규 회사 추가 시 여기만 갱신. CORPS 가 가장 기본 (CORPS_ALL/ACTIVE 미설정 시 fallback).
POLARIS_CORPS=00126380,00164779,00118804,01489648,00161383 #기업코드만추가
POLARIS_CORP_NAMES=삼성전자,SK하이닉스,동진쎄미켐,솔브레인,한미반도체

# (옵션) P-2.4 S-09: 적재 vs 노출 분리
#   CORPS_ALL    : 적재 대상 전체 (그래프·청크에 들어가는 회사, 없으면 CORPS 사용)
#   CORPS_ACTIVE : 검색·평가 노출 회사 subset (없으면 CORPS_ALL 사용)
# POLARIS_CORPS_ALL=00126380,00164779,00118804,01489648,00161383,00160843,00369657,00246417
# POLARIS_CORPS_ACTIVE=00126380,00164779
