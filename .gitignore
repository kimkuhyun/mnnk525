# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# ── Node / 프론트엔드 ──
node_modules/
dist/
dist-ssr/
*.local

# ── 환경 (시크릿) ──
.env
.env.*
!.env.example

# ── DB raw·로그·임시 (대용량·재생성 가능) ──
db/raw/_tmp_*/
db/logs/
db/**/*.log

# ── Claude (워크플로 스크립트·로컬 에이전트 산출·로컬 지침) ──
.claude/
/CLAUDE.md

# ── DB 덤프 폴더 (별도 전달 — 레포에 커밋 안 함) ──
/dump/

# ── 추출 런타임 작업물 (auto_runner가 생성·삭제하는 배치/결과) ──
db/graph/_auto/*
!db/graph/_auto/PROMPT.txt

# ── 브라우저/MCP 작업 잔재 ──
.playwright-mcp/

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
